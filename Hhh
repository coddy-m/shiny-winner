const express = require("express");
const jwt = require("jsonwebtoken");
const User = require("../models/User");
const { verifyToken } = require("../middleware/authMiddleware");

const router = express.Router();

/* 
REGISTER: Create new user account
*/
router.post("/register", async (req, res) => {
  try {
    const { email, password, name } = req.body;

    // Validate required fields
    if (!email || !password || !name) {
      return res.status(400).json({ error: "All fields required" });
    }

    // Check if user already exists
    const existingUser = await User.findOne({ email });
    if (existingUser) {
      return res.status(400).json({ error: "Email already in use" });
    }

    // Create new user
    // Password is automatically hashed by userSchema.pre("save")
    const user = new User({ email, password, name });
    await user.save();

    // Return success (don't send password back!)
    res.status(201).json({
      message: "User created successfully",
      user: {
        id: user._id,
        email: user.email,
        name: user.name
      }
    });
  } catch (error) {
    res.status(500).json({ error: "Registration failed" });
  }
});

/* 
LOGIN: Authenticate user, return JWT
*/
router.post("/login", async (req, res) => {
  try {
    const { email, password } = req.body;

    // Validate input
    if (!email || !password) {
      return res.status(400).json({ error: "Email and password required" });
    }

    // Find user by email
    const user = await User.findOne({ email });
    if (!user) {
      return res.status(401).json({ error: "Invalid email or password" });
    }

    // Compare provided password with stored hash
    // This calls the comparePassword method we defined in User.js
    const passwordMatch = await user.comparePassword(password);
    if (!passwordMatch) {
      return res.status(401).json({ error: "Invalid email or password" });
    }

    // Password correct! Create JWT token
    // Payload: user info to include in token
    // Secret: used to sign token (from .env)
    // Options: expiration time (7 days)
    const token = jwt.sign(
      {
        userId: user._id,
        email: user.email,
        name: user.name
      },
      process.env.JWT_SECRET,
      { expiresIn: "7d" }
    );

    // Return token to client
    // Client will store this in localStorage and send it with each request
    res.json({
      message: "Login successful",
      token,
      user: {
        id: user._id,
        email: user.email,
        name: user.name
      }
    });
  } catch (error) {
    res.status(500).json({ error: "Login failed" });
  }
});

/* 
GET CURRENT USER: Protected route
Requires valid JWT token
*/
router.get("/me", verifyToken, async (req, res) => {
  try {
    // verifyToken middleware already decoded the token
    // and put user info in req.user
    const user = await User.findById(req.user.userId).select("-password");

    if (!user) {
      return res.status(404).json({ error: "User not found" });
    }

    res.json(user);
  } catch (error) {
    res.status(500).json({ error: "Failed to fetch user" });
  }
});

/* 
LOGOUT: Client-side only
Just delete token from localStorage
*/
router.post("/logout", verifyToken, (req, res) => {
  // Note: JWT is stateless, so server doesn't "logout"
  // Client just deletes the token from localStorage
  res.json({ message: "Logged out successfully" });
});

module.exports = router;

